{
  "name": "山东信息职业技术学院总站门户平台",
  "version": "1.0.0",
  "description": "建设山东信息职业技术学院统一的门户平台，作为校园数字化服务的总入口。总站采用门户导航式架构，集成二手交易平台、个人课表、商家点评、学校新闻等核心功能模块。",
  "goals": [
    "提供统一的校园服务入口",
    "实现单点登录，一次登录访问所有分站",
    "各分站数据互通，用户体验一致"
  ],
  "successMetrics": [
    "用户活跃度 DAU/MAU",
    "各分站访问转化率",
    "用户满意度评分"
  ],
  "userStories": [
    {
      "id": "US-001",
      "title": "总站首页导航",
      "description": "作为山东信息职业技术学院师生，我希望在总站首页看到所有功能入口，以便快速访问需要的服务。",
      "acceptanceCriteria": [
        "首页展示四大核心功能入口卡片",
        "点击入口可跳转到对应分站",
        "显示用户登录状态",
        "未登录用户点击分站跳转到统一登录页"
      ],
      "priority": "P0"
    },
    {
      "id": "US-002",
      "title": "统一登录认证",
      "description": "作为用户，我希望一次登录后可以访问所有分站，无需重复登录。",
      "acceptanceCriteria": [
        "支持学号登录",
        "登录状态在各分站间共享",
        "Token 过期自动刷新或提示重新登录"
      ],
      "priority": "P0"
    },
    {
      "id": "US-003",
      "title": "二手交易平台",
      "description": "作为学生/商家，我希望发布和浏览二手商品信息。",
      "acceptanceCriteria": [
        "商品发布（标题、描述、价格、分类、图片）",
        "商品浏览（列表/网格视图）",
        "分类筛选（教材、电子、生活等）",
        "关键词搜索",
        "联系卖家（站内消息/联系方式展示）",
        "商品状态管理（在售/已售/下架）"
      ],
      "priority": "P0"
    },
    {
      "id": "US-004",
      "title": "个人课表 x 地图联动",
      "description": "作为学生，我希望查看课表时能快速定位教室位置，并获得上课提醒。",
      "acceptanceCriteria": [
        "课表展示（周视图/日视图切换）",
        "点击课程显示教室在地图上的位置",
        "教室地图可视化展示",
        "上课前自动提醒（可配置提前时间）",
        "显示距离和预计步行时间"
      ],
      "priority": "P0"
    },
    {
      "id": "US-005",
      "title": "商家点评",
      "description": "作为学生，我希望查看和发布对学校周边商家的评价。",
      "acceptanceCriteria": [
        "商家列表展示",
        "商家详情页（信息 + 评价 + 评分）",
        "用户发布评价（打分 + 文字 + 图片）",
        "商家排行榜（按评分/热度）",
        "商家分类（餐饮、购物、服务等）",
        "评价点赞/有用数"
      ],
      "priority": "P0"
    },
    {
      "id": "US-006",
      "title": "学校新闻",
      "description": "作为师生，我希望及时获取学校新闻动态。",
      "acceptanceCriteria": [
        "新闻列表（按时间排序）",
        "新闻分类（学术、活动、通知等）",
        "新闻详情页",
        "热门新闻推荐",
        "新闻搜索功能"
      ],
      "priority": "P0"
    }
  ],
  "functionalRequirements": [
    {
      "module": "总站门户",
      "requirements": [
        {"id": "FR-1.1", "description": "首页展示四大功能入口", "priority": "P0"},
        {"id": "FR-1.2", "description": "统一用户登录/注册", "priority": "P0"},
        {"id": "FR-1.3", "description": "登录状态管理（JWT/Session）", "priority": "P0"},
        {"id": "FR-1.4", "description": "个人中心（基本信息、访问记录）", "priority": "P1"},
        {"id": "FR-1.5", "description": "消息通知中心", "priority": "P2"}
      ]
    },
    {
      "module": "二手平台分站",
      "requirements": [
        {"id": "FR-2.1", "description": "商品发布（标题、描述、价格、分类、图片）", "priority": "P0"},
        {"id": "FR-2.2", "description": "商品列表展示（分页/无限滚动）", "priority": "P0"},
        {"id": "FR-2.3", "description": "商品分类筛选", "priority": "P0"},
        {"id": "FR-2.4", "description": "关键词搜索", "priority": "P0"},
        {"id": "FR-2.5", "description": "商品详情查看", "priority": "P0"},
        {"id": "FR-2.6", "description": "联系卖家功能", "priority": "P0"},
        {"id": "FR-2.7", "description": "我的商品管理（编辑/下架/删除）", "priority": "P1"},
        {"id": "FR-2.8", "description": "商品收藏功能", "priority": "P2"}
      ]
    },
    {
      "module": "个人课表 x 地图",
      "requirements": [
        {"id": "FR-3.1", "description": "课表数据导入/手动添加", "priority": "P0"},
        {"id": "FR-3.2", "description": "周视图/日视图展示", "priority": "P0"},
        {"id": "FR-3.3", "description": "点击课程显示教室位置", "priority": "P0"},
        {"id": "FR-3.4", "description": "校园地图可视化", "priority": "P0"},
        {"id": "FR-3.5", "description": "上课提醒（可配置提前时间）", "priority": "P1"},
        {"id": "FR-3.6", "description": "距离计算和步行时间估算", "priority": "P1"}
      ]
    },
    {
      "module": "商家点评分站",
      "requirements": [
        {"id": "FR-4.1", "description": "商家列表展示", "priority": "P0"},
        {"id": "FR-4.2", "description": "商家详情（信息 + 评价 + 评分）", "priority": "P0"},
        {"id": "FR-4.3", "description": "用户发布评价（1-5 星 + 文字 + 图片）", "priority": "P0"},
        {"id": "FR-4.4", "description": "商家排行榜", "priority": "P0"},
        {"id": "FR-4.5", "description": "商家分类筛选", "priority": "P0"},
        {"id": "FR-4.6", "description": "评价点赞/有用数统计", "priority": "P1"},
        {"id": "FR-4.7", "description": "商家认领/管理功能", "priority": "P2"}
      ]
    },
    {
      "module": "学校新闻分站",
      "requirements": [
        {"id": "FR-5.1", "description": "新闻列表（按时间排序）", "priority": "P0"},
        {"id": "FR-5.2", "description": "新闻分类", "priority": "P0"},
        {"id": "FR-5.3", "description": "新闻详情查看", "priority": "P0"},
        {"id": "FR-5.4", "description": "热门新闻推荐", "priority": "P1"},
        {"id": "FR-5.5", "description": "新闻搜索", "priority": "P1"}
      ]
    }
  ],
  "nonGoals": [
    "在线支付功能",
    "物流配送系统",
    "直播/短视频功能",
    "第三方 API 深度集成"
  ],
  "technicalStack": {
    "frontend": "Next.js 16 + React 19 + TypeScript + Tailwind CSS",
    "backend": "Next.js API Routes + Prisma ORM",
    "database": "SQLite (开发) / PostgreSQL (生产)",
    "auth": "NextAuth.js",
    "storage": "Vercel Blob / 对象存储",
    "deployment": "Vercel"
  },
  "dataModels": {
    "users": {
      "description": "用户表",
      "fields": ["id", "studentId", "name", "phone", "avatar", "school", "major", "class"]
    },
    "products": {
      "description": "商品表",
      "fields": ["id", "sellerId", "title", "description", "price", "category", "images", "status"]
    },
    "courses": {
      "description": "课程表",
      "fields": ["id", "userId", "courseName", "classroom", "time", "week"]
    },
    "merchants": {
      "description": "商家表",
      "fields": ["id", "name", "category", "address", "rating", "reviewCount"]
    },
    "reviews": {
      "description": "评价表",
      "fields": ["id", "merchantId", "userId", "rating", "content", "images"]
    },
    "news": {
      "description": "新闻表",
      "fields": ["id", "title", "content", "category", "publishedAt", "views"]
    }
  },
  "milestones": [
    {"name": "M1", "description": "总站框架 + 统一登录", "duration": "1-2 周"},
    {"name": "M2", "description": "二手平台分站", "duration": "2-3 周"},
    {"name": "M3", "description": "课表 x 地图分站", "duration": "2-3 周"},
    {"name": "M4", "description": "商家点评分站", "duration": "2 周"},
    {"name": "M5", "description": "学校新闻分站", "duration": "1 周"},
    {"name": "M6", "description": "联调测试 + 上线", "duration": "1-2 周"}
  ],
  "risks": [
    "教室地图数据需要手动采集",
    "课表数据导入依赖教务系统",
    "商家数据冷启动问题"
  ]
}
